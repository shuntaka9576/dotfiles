{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "fileSuggestion": {
    "type": "command",
    "command": "~/dotfiles/home-manager/programs/claude/file-suggestion.sh"
  },
  "env": {
    "CLAUDE_CODE_HIDE_CWD": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-5",
    "DISABLE_AUTOUPDATER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(aws logs get-*)",
      "Bash(aws logs describe-*)",
      "Bash(aws logs filter-*)",
      "Bash(aws logs tail *)",
      "Bash(aws logs start-query *)",
      "WebSearch"
    ],
    "defaultMode": "auto"
  },
  "model": "fable[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agentoast hook claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agentoast hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/dotfiles/home-manager/programs/claude/statusline/statusline.ts"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "harness": {
      "source": {
        "source": "github",
        "repo": "shuntaka9576/harness-template-min"
      }
    }
  },
  "language": "Japanese",
  "feedbackSurveyRate": 0,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true
}
